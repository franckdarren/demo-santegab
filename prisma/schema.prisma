// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  SUPER_ADMIN
  ADMIN
  MEDECIN
  INFIRMIER
  LABORANTIN
  RADIOLOGUE
  PHARMACIEN
  COMPTABLE
  ADMINISTRATIF
}

enum StatutConsultation {
  EN_ATTENTE
  EN_COURS
  TERMINEE
  ANNULEE
}

enum StatutFacture {
  EN_ATTENTE
  PARTIELLEMENT_PAYEE
  PAYEE
  ANNULEE
}

enum ModePaiement {
  ESPECES
  CARTE_BANCAIRE
  MOBILE_MONEY
  ASSURANCE
  CHEQUE
}

enum Sexe {
  MASCULIN
  FEMININ
}

enum StatutExamen {
  EN_ATTENTE
  EN_COURS
  RESULTAT_SAISI
  VALIDE
  ANNULE
}

enum TypeExamenLabo {
  BILAN_SANGUIN
  BILAN_URINAIRE
  BACTERIOLOGIE
  PARASITOLOGIE
  SEROLOGIE
  BIOCHIMIE
  HEMATOLOGIE
  AUTRE
}

enum TypeExamenImagerie {
  RADIOGRAPHIE
  ECHOGRAPHIE
  SCANNER
  IRM
  MAMMOGRAPHIE
  AUTRE
}

enum CategorieArticle {
  MEDICAMENT
  CONSOMMABLE
  EQUIPEMENT
  AUTRE
}

enum TypeMouvement {
  ENTREE
  SORTIE
  AJUSTEMENT
  PEREMPTION
}

enum TypeEcriture {
  RECETTE
  DEPENSE
  AJUSTEMENT
}

enum CategorieDepense {
  SALAIRES
  MEDICAMENTS
  EQUIPEMENT
  LOYER
  ELECTRICITE
  EAU
  TELEPHONE
  FOURNITURES
  MAINTENANCE
  AUTRE
}

// ============================================================
// TABLE : hospitals
// ============================================================
model Hospital {
  id         String   @id @default(uuid())
  nom        String
  adresse    String?
  ville      String?
  telephone  String?
  email      String?
  logo_url   String?
  est_actif  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  utilisateurs     Utilisateur[]
  patients         PatientHospital[]
  consultations    Consultation[]
  factures         Facture[]
  examens_labo     ExamenLabo[]      @relation("HospitalExamensLabo")
  examens_imagerie ExamenImagerie[]  @relation("HospitalExamensImagerie")
  articles_stock   ArticleStock[]    @relation("HospitalArticlesStock")
  mouvements_stock MouvementStock[]  @relation("HospitalMouvementsStock")
  ecritures_comptables EcritureComptable[] @relation("HospitalEcritures")

  @@map("hospitals")
}

// ============================================================
// TABLE : utilisateurs
// ============================================================
model Utilisateur {
  id           String   @id @default(uuid())
  hospital_id  String
  supabase_uid String?  @unique
  nom          String
  prenom       String
  email        String   @unique
  telephone    String?
  role         Role     @default(ADMINISTRATIF)
  est_actif    Boolean  @default(true)
  avatar_url   String?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  hospital                   Hospital         @relation(fields: [hospital_id], references: [id])
  consultations              Consultation[]   @relation("MedecinConsultations")
  examens_labo_prescrits     ExamenLabo[]     @relation("MedecinExamensLabo")
  examens_imagerie_prescrits ExamenImagerie[] @relation("MedecinExamensImagerie")

  @@index([hospital_id])
  @@map("utilisateurs")
}

// ============================================================
// TABLE : patients
// ============================================================
model Patient {
  id             String    @id @default(uuid())
  numero_dossier String    @unique
  nom            String
  prenom         String
  date_naissance DateTime?
  sexe           Sexe?
  telephone      String?
  email          String?
  adresse        String?
  ville          String?
  groupe_sanguin String?
  allergies      String?
  antecedents    String?
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  hospitalisations PatientHospital[]
  consultations    Consultation[]    @relation("PatientConsultations")
  factures         Facture[]         @relation("PatientFactures")
  examens_labo     ExamenLabo[]      @relation("PatientExamensLabo")
  examens_imagerie ExamenImagerie[]  @relation("PatientExamensImagerie")

  @@map("patients")
}

// ============================================================
// TABLE : patient_hospitals
// ============================================================
model PatientHospital {
  id               String   @id @default(uuid())
  patient_id       String
  hospital_id      String
  assurance_nom    String?
  assurance_numero String?
  taux_couverture  Float?   @default(0)
  medecin_traitant String?
  est_actif        Boolean  @default(true)
  created_at       DateTime @default(now())

  patient  Patient  @relation(fields: [patient_id], references: [id])
  hospital Hospital @relation(fields: [hospital_id], references: [id])

  @@unique([patient_id, hospital_id])
  @@index([hospital_id])
  @@map("patient_hospitals")
}

// ============================================================
// TABLE : consultations
// ============================================================
model Consultation {
  id                String             @id @default(uuid())
  hospital_id       String
  patient_id        String
  medecin_id        String
  statut            StatutConsultation @default(EN_ATTENTE)
  motif             String?
  diagnostic        String?
  notes             String?
  poids_kg          Float?
  taille_cm         Float?
  tension           String?
  temperature       Float?
  date_consultation DateTime           @default(now())
  created_at        DateTime           @default(now())
  updated_at        DateTime           @updatedAt

  hospital      Hospital       @relation(fields: [hospital_id], references: [id])
  patient       Patient        @relation("PatientConsultations", fields: [patient_id], references: [id])
  medecin       Utilisateur    @relation("MedecinConsultations", fields: [medecin_id], references: [id])
  prescriptions Prescription[]
  facture       Facture?

  @@index([hospital_id])
  @@index([patient_id])
  @@map("consultations")
}

// ============================================================
// TABLE : prescriptions
// ============================================================
model Prescription {
  id              String   @id @default(uuid())
  consultation_id String
  medicament      String
  dosage          String?
  frequence       String?
  duree           String?
  instructions    String?
  created_at      DateTime @default(now())

  consultation Consultation @relation(fields: [consultation_id], references: [id])

  @@index([consultation_id])
  @@map("prescriptions")
}

// ============================================================
// TABLE : factures
// ============================================================
model Facture {
  id                String        @id @default(uuid())
  hospital_id       String
  patient_id        String
  consultation_id   String?       @unique
  numero_facture    String        @unique
  statut            StatutFacture @default(EN_ATTENTE)
  montant_total     Float
  montant_assurance Float         @default(0)
  montant_patient   Float
  mode_paiement     ModePaiement?
  date_paiement     DateTime?
  notes             String?
  created_at        DateTime      @default(now())
  updated_at        DateTime      @updatedAt

  hospital     Hospital       @relation(fields: [hospital_id], references: [id])
  patient      Patient        @relation("PatientFactures", fields: [patient_id], references: [id])
  consultation Consultation?  @relation(fields: [consultation_id], references: [id])
  lignes       LigneFacture[]

  @@index([hospital_id])
  @@index([patient_id])
  @@map("factures")
}

// ============================================================
// TABLE : ligne_factures
// ============================================================
model LigneFacture {
  id            String   @id @default(uuid())
  facture_id    String
  description   String
  quantite      Int      @default(1)
  prix_unitaire Float
  montant_total Float
  created_at    DateTime @default(now())

  facture Facture @relation(fields: [facture_id], references: [id])

  @@index([facture_id])
  @@map("ligne_factures")
}

// ============================================================
// TABLE : examens_labo
// ============================================================
model ExamenLabo {
  id          String         @id @default(uuid())
  hospital_id String
  patient_id  String
  medecin_id  String
  type_examen TypeExamenLabo
  statut      StatutExamen   @default(EN_ATTENTE)
  resultats   String?
  fichier_url String?
  fichier_nom String?
  valide_par  String?
  valide_le   DateTime?
  notes       String?
  urgence     Boolean        @default(false)
  created_at  DateTime       @default(now())
  updated_at  DateTime       @updatedAt

  hospital Hospital    @relation("HospitalExamensLabo", fields: [hospital_id], references: [id])
  patient  Patient     @relation("PatientExamensLabo", fields: [patient_id], references: [id])
  medecin  Utilisateur @relation("MedecinExamensLabo", fields: [medecin_id], references: [id])

  @@index([hospital_id])
  @@index([patient_id])
  @@map("examens_labo")
}

// ============================================================
// TABLE : examens_imagerie
// ============================================================
model ExamenImagerie {
  id              String             @id @default(uuid())
  hospital_id     String
  patient_id      String
  medecin_id      String
  type_examen     TypeExamenImagerie
  statut          StatutExamen       @default(EN_ATTENTE)
  resultats       String?
  fichier_url     String?
  fichier_nom     String?
  valide_par      String?
  valide_le       DateTime?
  notes           String?
  urgence         Boolean            @default(false)
  zone_anatomique String?
  created_at      DateTime           @default(now())
  updated_at      DateTime           @updatedAt

  hospital Hospital    @relation("HospitalExamensImagerie", fields: [hospital_id], references: [id])
  patient  Patient     @relation("PatientExamensImagerie", fields: [patient_id], references: [id])
  medecin  Utilisateur @relation("MedecinExamensImagerie", fields: [medecin_id], references: [id])

  @@index([hospital_id])
  @@index([patient_id])
  @@map("examens_imagerie")
}

// ============================================================
// TABLE : articles_stock
// ============================================================
model ArticleStock {
  id              String           @id @default(uuid())
  hospital_id     String
  nom             String
  categorie       CategorieArticle @default(MEDICAMENT)
  description     String?
  unite           String           @default("comprimé")
  quantite_stock  Int              @default(0)
  seuil_alerte    Int              @default(10)
  prix_unitaire   Float            @default(0)
  date_peremption DateTime?
  code_article    String?
  est_actif       Boolean          @default(true)
  created_at      DateTime         @default(now())
  updated_at      DateTime         @updatedAt

  hospital   Hospital         @relation("HospitalArticlesStock", fields: [hospital_id], references: [id])
  mouvements MouvementStock[] @relation("ArticleMouvements")

  @@index([hospital_id])
  @@map("articles_stock")
}

// ============================================================
// TABLE : mouvements_stock
// ============================================================
model MouvementStock {
  id             String        @id @default(uuid())
  hospital_id    String
  article_id     String
  type_mouvement TypeMouvement
  quantite       Int
  quantite_avant Int
  quantite_apres Int
  motif          String?
  utilisateur_id String?
  created_at     DateTime      @default(now())

  hospital Hospital     @relation("HospitalMouvementsStock", fields: [hospital_id], references: [id])
  article  ArticleStock @relation("ArticleMouvements", fields: [article_id], references: [id])

  @@index([hospital_id])
  @@index([article_id])
  @@map("mouvements_stock")
}

model EcritureComptable {
  id              String            @id @default(uuid())
  hospital_id     String
  type_ecriture   TypeEcriture
  categorie       CategorieDepense?
  libelle         String
  montant         Float
  date_ecriture   DateTime          @default(now())
  reference       String?
  facture_id      String?
  utilisateur_id  String?
  notes           String?
  created_at      DateTime          @default(now())

  hospital Hospital @relation("HospitalEcritures", fields: [hospital_id], references: [id])

  @@index([hospital_id])
  @@index([type_ecriture])
  @@index([date_ecriture])
  @@map("ecritures_comptables")
}